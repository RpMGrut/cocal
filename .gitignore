# --- Gradle ---
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# --- Kotlin ---
.kotlin/
*.kotlin_module

# --- IntelliJ IDEA ---
# Ignore everything in .idea/ by default. If you ever want to share a specific
# IDEA file with the team (code style, inspection profile, etc.), add an
# explicit negation below:
#   !.idea/codeStyles/
.idea/
*.iws
*.iml
*.ipr
out/
!**/src/main/**/out/
!**/src/test/**/out/

# --- Eclipse ---
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache
bin/
!**/src/main/**/bin/
!**/src/test/**/bin/

# --- NetBeans ---
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# --- VS Code ---
.vscode/

# --- Claude Code working directory ---
.claude/

# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini

# --- Logs & crash dumps ---
*.log
hs_err_pid*.log
replay_pid*.log

# --- Secrets ---
*.env
.env
.env.*
!.env.example
